{
  "schemaVersion": 1,
  "id": "msp.chat-ui.renderers.default",
  "name": "Default",
  "description": "MSP default chat UI renderer: markstream markdown, Codex-style animation, user bubbles, assistant open content, and tool activity blocks.",
  "capabilities": {
    "timeline": true,
    "runtimeEvents": true,
    "streamingDelta": true,
    "payloadPatch": true,
    "presentationUpdate": true,
    "darkTheme": true,
    "mobileLayout": true,
    "math": "katex",
    "codeBlocks": true,
    "toolActivity": true,
    "messageActions": true,
    "displayWindow": true,
    "textSelection": true,
    "videoProgress": true,
    "selectionOverlay": true
  },
  "assetBasePath": "runtime/assets",
  "sourceAssetManifestPath": "runtime/assets/Math/chat-transcript-document-assets.json",
  "contractScripts": [
    "../../Contracts/runtime/status.js",
    "../../Contracts/runtime/timeline.js",
    "../../Contracts/runtime/events.js"
  ],
  "projectionScripts": [
    "../../Projection/runtime/identity.js",
    "../../Projection/runtime/default/activity-adapter.js",
    "../../Projection/runtime/default/block-adapter.js",
    "../../Projection/runtime/default/message-adapter.js",
    "../../Projection/runtime/default/action-policy-adapter.js",
    "../../Projection/runtime/default/presentation-adapter.js",
    "../../Projection/runtime/default-adapter.js",
    "../../Projection/runtime/payload-diff.js",
    "../../Projection/runtime/render-planner.js",
    "../../Projection/runtime/stream-delta.js",
    "../../Projection/runtime/timeline-store.js",
    "../../Projection/runtime/index.js"
  ],
  "rendererAPIScripts": [
    "runtime/api/default-renderer-api.js"
  ],
  "hostCompatibilityScripts": [
    "runtime/bridge/msp-host-bridge-compat.js"
  ],
  "knowledgeMapScriptPaths": [
    "KnowledgeMap/d3.min.js",
    "KnowledgeMap/markmap-view.js"
  ],
  "defaultPresentation": {
    "theme": "light",
    "readexTranscriptTheme": "codex",
    "readexMarkdownRendererProfile": "markstream-readex-fade",
    "readexMarkstreamCodeTheme": "vitesse",
    "bodyFontSize": 15.5,
    "roleFontSize": 12,
    "metaFontSize": 11,
    "supportFontSize": 14,
    "messageGap": 12,
    "pagePaddingX": 12,
    "pagePaddingY": 18,
    "pagePaddingTop": 56.5,
    "pagePaddingBottom": 18,
    "usesContainerRelativeMessageLayout": true,
    "containerRelativeBubbleBaseWidth": 720,
    "containerRelativeGrowthReserveRatio": 0.35,
    "containerRelativeMinimumGrowthReserve": 0,
    "containerRelativeMaximumGrowthReserve": 120,
    "assistantBubbleMaxWidth": 720,
    "userBubbleMaxWidth": 720,
    "assistantBubbleOffsetX": 0,
    "userBubbleOffsetX": 0,
    "assistantBubbleOffsetY": 0,
    "userBubbleOffsetY": 0,
    "assistantBubblePaddingX": 16,
    "userBubblePaddingX": 16,
    "assistantBubblePaddingY": 12,
    "userBubblePaddingY": 12,
    "assistantBubbleCornerRadius": 22,
    "generatedImageCornerRadius": 22,
    "userBubbleCornerRadius": 22,
    "assistantContentBaseWidth": 640,
    "userContentBaseWidth": 640,
    "assistantContentMaxWidth": 640,
    "userContentMaxWidth": 640,
    "assistantContentOffsetX": 0,
    "userContentOffsetX": 0,
    "assistantContentOffsetY": 0,
    "userContentOffsetY": 0,
    "pageZoom": 1,
    "readexMessageFontWeight": 430,
    "showsAssistantBubbleBackground": false,
    "showsUserBubbleBackground": true,
    "assistantBubbleBackgroundColor": "rgba(255, 255, 255, 0)",
    "userBubbleBackgroundColor": "rgba(0, 0, 0, 0.055)",
    "toolbarHoverFill": "rgba(20, 33, 50, 0.08)",
    "controlBackground": "rgba(248, 248, 249, 0.98)",
    "tooltipBorder": "rgba(23, 34, 51, 0.08)",
    "searchHighlightColor": "rgba(255, 206, 84, 0.56)",
    "searchActiveHighlightColor": "rgba(255, 145, 48, 0.92)",
    "searchActiveHighlightRingColor": "rgba(255, 145, 48, 0.28)",
    "searchActiveHighlightTextColor": "#1f1200",
    "themeOverrides": {
      "dark": {
        "userBubbleBackgroundColor": "rgba(255, 255, 255, 0.10)",
        "assistantBubbleBackgroundColor": "rgba(255, 255, 255, 0)",
        "toolbarHoverFill": "rgba(255, 255, 255, 0.08)",
        "controlBackground": "rgba(30, 34, 40, 0.94)",
        "tooltipBorder": "rgba(255, 255, 255, 0.14)",
        "searchHighlightColor": "rgba(255, 214, 102, 0.42)",
        "searchActiveHighlightColor": "rgba(255, 171, 64, 0.88)",
        "searchActiveHighlightRingColor": "rgba(255, 206, 120, 0.42)",
        "searchActiveHighlightTextColor": "#211300",
        "style": {
          "appBackground": "#0f141b",
          "title": "#e6edf5",
          "secondary": "rgba(230, 237, 245, 0.68)",
          "assistantBackground": "rgba(255, 255, 255, 0)",
          "assistantBorder": "rgba(255, 255, 255, 0.12)",
          "userBackground": "rgba(255, 255, 255, 0.10)",
          "userBorder": "rgba(255, 255, 255, 0.14)",
          "assistantAccent": "#8abdf2",
          "userAccent": "#b8c0cc",
          "chipBackground": "rgba(255, 255, 255, 0.08)",
          "codeBackground": "rgba(255, 255, 255, 0.08)",
          "codeBackgroundSoft": "rgba(255, 255, 255, 0.07)",
          "blockquoteBorder": "rgba(138, 189, 242, 0.30)",
          "readexChatDividerColor": "rgba(255, 255, 255, 0.16)"
        }
      }
    },
    "style": {
      "appBackground": "#f4f1ea",
      "title": "#172233",
      "secondary": "rgba(23, 34, 51, 0.68)",
      "assistantBackground": "rgba(255, 255, 255, 0)",
      "assistantBorder": "rgba(23, 34, 51, 0.08)",
      "userBackground": "rgba(0, 0, 0, 0.055)",
      "userBorder": "rgba(23, 34, 51, 0.08)",
      "assistantAccent": "#1b67a8",
      "userAccent": "#666666",
      "chipBackground": "rgba(20, 33, 50, 0.06)",
      "codeBackground": "rgba(18, 32, 49, 0.07)",
      "codeBackgroundSoft": "rgba(18, 32, 49, 0.06)",
      "blockquoteBorder": "rgba(18, 84, 145, 0.24)",
      "readexChatDividerColor": "rgba(20, 28, 38, 0.16)"
    }
  },
  "hostBridge": {
    "channels": [
      "messageAction",
      "openAttachment",
      "selectLayoutLabComponent",
      "presentationProbe",
      "codeBlockLayoutChanged",
      "copyCode",
      "explanationAnchor",
      "__CHAT_TRANSCRIPT_SELECTION_CONTEXT_MENU_HANDLER_NAME__"
    ],
    "dispatchEventName": "msp-chat-ui-host-message"
  }
}
