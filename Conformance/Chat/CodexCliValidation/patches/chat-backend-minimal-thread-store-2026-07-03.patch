+
+/// Process-scoped configuration for the `.chat` validation thread store.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct ChatThreadStoreConfig {
+    pub root: PathBuf,
+}
+
+/// `.chat` package-backed [`ThreadStore`] used by the source-level validation
+/// package.
+#[derive(Clone, Debug)]
+pub struct ChatThreadStore {
+    config: ChatThreadStoreConfig,
+    live_threads: Arc<Mutex<HashSet<ThreadId>>>,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+struct ChatManifest {
+    format: String,
+    version: u32,
+    profiles: Vec<String>,
+    capabilities: Vec<String>,
+    thread_id: ThreadId,
+    created_at: DateTime<Utc>,
+    updated_at: DateTime<Utc>,
+    archived_at: Option<DateTime<Utc>>,
+    create_params: CreateThreadParams,
+    metadata_patch: ThreadMetadataPatch,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+struct JournalEntry {
+    entry_type: String,
+    created_at: DateTime<Utc>,
+    commit_seq: u64,
+    thread_id: ThreadId,
+    #[serde(default)]
+    source_transport: SourceTransportEnvelope,
+    item: RolloutItem,
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+struct SourceTransportEnvelope {
+    schema: String,
+    payload: serde_json::Value,
+}
+
+impl Default for SourceTransportEnvelope {
+    fn default() -> Self {
+        Self {
+            schema: "msp.chat.source_transport.v1".to_string(),
+            payload: serde_json::Value::Null,
+        }
+    }
+}
+
+#[derive(Clone, Debug, Serialize, Deserialize)]
+struct TimelineEvent {
+    id: String,
+    #[serde(rename = "type")]
+    event_type: String,
+    seq: u64,
+    commit_seq: u64,
+    created_at: DateTime<Utc>,
+    durability: String,
+    thread_id: ThreadId,
+    source_transport_ref: String,
+    source_item_kind: String,
+    payload: serde_json::Value,
+}
+
+impl ChatThreadStore {
+    pub fn new(config: ChatThreadStoreConfig) -> Self {
+        Self {
+            config,
+            live_threads: Arc::new(Mutex::new(HashSet::new())),
+        }
+    }
+
+    fn package_path(&self, thread_id: ThreadId) -> PathBuf {
+        self.config.root.join(format!("{thread_id}.chat"))
+    }
+
+    fn cold_package_path(&self, thread_id: ThreadId) -> PathBuf {
+        self.config.root.join(format!("{thread_id}.chat.cold"))
+    }
+
+    fn package_from_path(&self, path: &Path) -> PathBuf {
+        if path.is_dir() {
+            return path.to_path_buf();
+        }
+        path.parent()
+            .map(Path::to_path_buf)
+            .unwrap_or_else(|| path.to_path_buf())
+    }
+
+    fn existing_package_path(&self, thread_id: ThreadId) -> ThreadStoreResult<PathBuf> {
+        let package_path = self.package_path(thread_id);
+        if package_path.exists() {
+            return Ok(package_path);
+        }
+        let cold_package_path = self.cold_package_path(thread_id);
+        if cold_package_path.exists() {
+            return Ok(cold_package_path);
+        }
+        Err(ThreadStoreError::ThreadNotFound { thread_id })
+    }
+
+    fn writable_package_path(&self, thread_id: ThreadId) -> ThreadStoreResult<PathBuf> {
+        materialize_cold_package(
+            self.package_path(thread_id),
+            self.cold_package_path(thread_id),
+        )
+    }
+
+    fn writable_package_from_path(&self, path: &Path) -> ThreadStoreResult<PathBuf> {
+        let package_path = self.package_from_path(path);
+        let plain_path = cold_to_plain_package_path(&package_path);
+        let cold_path = if is_cold_package_path(&package_path) {
+            package_path
+        } else {
+            plain_to_cold_package_path(&plain_path)
+        };
+        materialize_cold_package(plain_path, cold_path)
+    }
+
+    async fn create_thread_inner(&self, params: CreateThreadParams) -> ThreadStoreResult<()> {
+        reject_paginated_history_mode(params.history_mode)?;
+        fs::create_dir_all(&self.config.root).map_err(io_error)?;
+        let package_path = self.package_path(params.thread_id);
+        if package_path.exists() || self.cold_package_path(params.thread_id).exists() {
+            return Err(ThreadStoreError::Conflict {
+                message: format!("thread {} already exists", params.thread_id),
+            });
+        }
+        ensure_package_layout(&package_path)?;
+        let now = Utc::now();
+        let manifest = ChatManifest {
+            format: "msp.chat".to_string(),
+            version: 1,
+            profiles: vec![
+                "core-timeline".to_string(),
+                "agent-timeline".to_string(),
+                "projection-cache".to_string(),
+                "resumable-context".to_string(),
+                "runtime-journal".to_string(),
+            ],
+            capabilities: vec![
+                "read_core".to_string(),
+                "write_core".to_string(),
+                "generate_projection".to_string(),
+                "replay_journal".to_string(),
+                "preserve_unknown_events".to_string(),
+            ],
+            thread_id: params.thread_id,
+            created_at: now,
+            updated_at: now,
+            archived_at: None,
+            create_params: params.clone(),
+            metadata_patch: ThreadMetadataPatch::default(),
+        };
+        write_manifest(&package_path, &manifest)?;
+        reset_canonical_files(&package_path)?;
+
+        let session_meta = session_meta_from_create_params(&params);
+        append_canonical_items(
+            &package_path,
+            params.thread_id,
+            vec![RolloutItem::SessionMeta(SessionMetaLine {
+                meta: session_meta,
+                git: None,
+            })],
+        )?;
+        rebuild_projections(&package_path)?;
+        write_thread_index(
+            &package_path,
+            &stored_thread_from_manifest(&manifest, None, None)?,
+        )?;
+        self.live_threads.lock().await.insert(params.thread_id);
+        Ok(())
+    }
+
+    async fn resume_thread_inner(&self, params: ResumeThreadParams) -> ThreadStoreResult<()> {
+        let package_path = if let Some(rollout_path) = params.rollout_path.as_ref() {
+            self.writable_package_from_path(rollout_path)?
+        } else {
+            self.writable_package_path(params.thread_id)?
+        };
+        let mut manifest = read_manifest(&package_path)?;
+        if manifest.thread_id != params.thread_id {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!(
+                    "package {} belongs to thread {}, not {}",
+                    package_path.display(),
+                    manifest.thread_id,
+                    params.thread_id
+                ),
+            });
+        }
+        if manifest.archived_at.is_some() && !params.include_archived {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("thread {} is archived", params.thread_id),
+            });
+        }
+        let history_mode = params
+            .history
+            .as_deref()
+            .map(Vec::as_slice)
+            .map(canonical_history_mode_from_rollout_items)
+            .unwrap_or(manifest.create_params.history_mode);
+        reject_paginated_history_mode(history_mode)?;
+        manifest.metadata_patch.cwd = params.metadata.cwd;
+        manifest.metadata_patch.model_provider = Some(params.metadata.model_provider);
+        manifest.metadata_patch.memory_mode = Some(params.metadata.memory_mode);
+        manifest.updated_at = Utc::now();
+        write_manifest(&package_path, &manifest)?;
+        let stored = stored_thread_from_package(&package_path, false)?;
+        write_thread_index(&package_path, &stored)?;
+        self.live_threads.lock().await.insert(params.thread_id);
+        Ok(())
+    }
+
+    async fn append_items_inner(&self, params: AppendThreadItemsParams) -> ThreadStoreResult<()> {
+        let canonical_items = persisted_rollout_items(params.items.as_slice());
+        if canonical_items.is_empty() {
+            return Ok(());
+        }
+        let package_path = self.writable_package_path(params.thread_id)?;
+        let mut manifest = read_manifest(&package_path)?;
+        let failpoint_needle_matches = validation_failpoint_needle_matches(&canonical_items);
+        append_canonical_items(&package_path, params.thread_id, canonical_items)?;
+        manifest.updated_at = Utc::now();
+        write_manifest(&package_path, &manifest)?;
+        validation_failpoint_if(
+            "after-canonical-before-projections",
+            failpoint_needle_matches,
+        );
+        rebuild_projections(&package_path)?;
+        let stored = stored_thread_from_package(&package_path, false)?;
+        write_thread_index(&package_path, &stored)?;
+        Ok(())
+    }
+
+    async fn load_history_inner(
+        &self,
+        params: LoadThreadHistoryParams,
+    ) -> ThreadStoreResult<StoredThreadHistory> {
+        let package_path = self.existing_package_path(params.thread_id)?;
+        let manifest = read_manifest(&package_path)?;
+        if manifest.archived_at.is_some() && !params.include_archived {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("thread {} is archived", params.thread_id),
+            });
+        }
+        reject_paginated_history_mode(manifest.create_params.history_mode)?;
+        Ok(StoredThreadHistory {
+            thread_id: params.thread_id,
+            items: read_journal_items(&package_path)?,
+        })
+    }
+
+    async fn read_thread_inner(&self, params: ReadThreadParams) -> ThreadStoreResult<StoredThread> {
+        let package_path =
+            self.existing_package_path(params.thread_id)
+                .map_err(|err| match err {
+                    ThreadStoreError::ThreadNotFound { thread_id }
+                        if thread_id == params.thread_id =>
+                    {
+                        ThreadStoreError::InvalidRequest {
+                            message: format!("no rollout found for thread id {thread_id}"),
+                        }
+                    }
+                    err => err,
+                })?;
+        let manifest = read_manifest(&package_path)?;
+        if manifest.archived_at.is_some() && !params.include_archived {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("thread {} is archived", params.thread_id),
+            });
+        }
+        if params.include_history {
+            reject_paginated_history_mode(manifest.create_params.history_mode)?;
+        }
+        stored_thread_from_package_repairing_index(&package_path, params.include_history)
+    }
+
+    async fn read_thread_by_path_inner(
+        &self,
+        params: ReadThreadByRolloutPathParams,
+    ) -> ThreadStoreResult<StoredThread> {
+        let package_path = self.package_from_path(&params.rollout_path);
+        let manifest = read_manifest(&package_path)?;
+        if manifest.archived_at.is_some() && !params.include_archived {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("thread {} is archived", manifest.thread_id),
+            });
+        }
+        if params.include_history {
+            reject_paginated_history_mode(manifest.create_params.history_mode)?;
+        }
+        stored_thread_from_package_repairing_index(&package_path, params.include_history)
+    }
+
+    async fn list_threads_inner(&self, params: ListThreadsParams) -> ThreadStoreResult<ThreadPage> {
+        let mut items = Vec::new();
+        let mut relation_universe = Vec::new();
+        for package_path in package_paths(&self.config.root)? {
+            let Ok(thread) = stored_thread_from_package_repairing_index(&package_path, false)
+            else {
+                continue;
+            };
+            if params.relation_filter.is_some() {
+                relation_universe.push((thread.thread_id, thread.parent_thread_id));
+            }
+            if params.archived != thread.archived_at.is_some() {
+                continue;
+            }
+            if !params.allowed_sources.is_empty()
+                && !params.allowed_sources.contains(&thread.source)
+            {
+                continue;
+            }
+            if let Some(model_providers) = params.model_providers.as_ref()
+                && !model_providers.is_empty()
+                && !model_providers.contains(&thread.model_provider)
+            {
+                continue;
+            }
+            if let Some(cwd_filters) = params.cwd_filters.as_ref() {
+                if cwd_filters.is_empty() {
+                    continue;
+                }
+                if !cwd_filters.iter().any(|cwd| cwd == &thread.cwd) {
+                    continue;
+                }
+            }
+            if let Some(search_term) = params.search_term.as_ref()
+                && !thread_matches_search(&thread, search_term)
+            {
+                continue;
+            }
+            items.push(thread);
+        }
+
+        apply_relation_filter(&mut items, &relation_universe, params.relation_filter);
+        sort_threads(&mut items, params.sort_key, params.sort_direction);
+        paginate_threads(
+            items,
+            params.page_size,
+            params.cursor,
+            params.sort_key,
+            params.sort_direction,
+            params.relation_filter.is_some(),
+        )
+    }
+
+    async fn search_threads_inner(
+        &self,
+        params: SearchThreadsParams,
+    ) -> ThreadStoreResult<ThreadSearchPage> {
+        let mut matches = Vec::new();
+        for package_path in package_paths(&self.config.root)? {
+            let thread = match stored_thread_from_package_repairing_index(&package_path, false) {
+                Ok(thread) => thread,
+                Err(_) => continue,
+            };
+            if params.archived != thread.archived_at.is_some() {
+                continue;
+            }
+            if !params.allowed_sources.is_empty()
+                && !params.allowed_sources.contains(&thread.source)
+            {
+                continue;
+            }
+            let journal_items = read_journal_items(&package_path).unwrap_or_default();
+            let snippet_from_history =
+                first_journal_content_match_snippet(&journal_items, &params.search_term);
+            if snippet_from_history.is_none()
+                && !thread_matches_search(&thread, &params.search_term)
+            {
+                continue;
+            }
+            let snippet = snippet_from_history
+                .or_else(|| thread.first_user_message.clone())
+                .unwrap_or_else(|| {
+                    if thread.preview.is_empty() {
+                        params.search_term.clone()
+                    } else {
+                        thread.preview.clone()
+                    }
+                });
+            matches.push(StoredThreadSearchResult { thread, snippet });
+        }
+        sort_search_results(&mut matches, params.sort_key, params.sort_direction);
+        paginate_search_results(
+            matches,
+            params.page_size,
+            params.cursor,
+            params.sort_key,
+            params.sort_direction,
+        )
+    }
+
+    async fn update_thread_metadata_inner(
+        &self,
+        params: UpdateThreadMetadataParams,
+    ) -> ThreadStoreResult<StoredThread> {
+        let package_path = self.writable_package_path(params.thread_id)?;
+        let mut manifest = read_manifest(&package_path)?;
+        if manifest.archived_at.is_some() && !params.include_archived {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("thread {} is archived", params.thread_id),
+            });
+        }
+        manifest.metadata_patch.merge(params.patch);
+        manifest.updated_at = Utc::now();
+        write_manifest(&package_path, &manifest)?;
+        let stored = stored_thread_from_package(&package_path, false)?;
+        write_thread_index(&package_path, &stored)?;
+        Ok(stored)
+    }
+
+    async fn archive_thread_inner(&self, params: ArchiveThreadParams) -> ThreadStoreResult<()> {
+        let package_path = self.writable_package_path(params.thread_id)?;
+        let mut manifest = read_manifest(&package_path)?;
+        manifest.archived_at = Some(Utc::now());
+        manifest.updated_at = Utc::now();
+        write_manifest(&package_path, &manifest)?;
+        validation_failpoint("after-lifecycle-manifest-before-index");
+        let stored = stored_thread_from_package(&package_path, false)?;
+        write_thread_index(&package_path, &stored)?;
+        Ok(())
+    }
+
+    async fn unarchive_thread_inner(
+        &self,
+        params: ArchiveThreadParams,
+    ) -> ThreadStoreResult<StoredThread> {
+        let package_path = self.writable_package_path(params.thread_id)?;
+        let mut manifest = read_manifest(&package_path)?;
+        manifest.archived_at = None;
+        manifest.updated_at = Utc::now();
+        write_manifest(&package_path, &manifest)?;
+        validation_failpoint("after-lifecycle-manifest-before-index");
+        let stored = stored_thread_from_package(&package_path, false)?;
+        write_thread_index(&package_path, &stored)?;
+        Ok(stored)
+    }
+
+    async fn delete_thread_inner(&self, params: DeleteThreadParams) -> ThreadStoreResult<()> {
+        let package_path = self.package_path(params.thread_id);
+        let cold_package_path = self.cold_package_path(params.thread_id);
+        if !package_path.exists() && !cold_package_path.exists() {
+            return Err(ThreadStoreError::InvalidRequest {
+                message: format!("no rollout found for thread id {}", params.thread_id),
+            });
+        }
+        if package_path.exists() {
+            fs::remove_dir_all(package_path).map_err(io_error)?;
+        }
+        validation_failpoint("after-delete-plain-package-before-cold-package");
+        if cold_package_path.exists() {
+            fs::remove_dir_all(cold_package_path).map_err(io_error)?;
+        }
+        validation_failpoint("after-delete-cold-package");
+        self.live_threads.lock().await.remove(&params.thread_id);
+        Ok(())
+    }
+}
