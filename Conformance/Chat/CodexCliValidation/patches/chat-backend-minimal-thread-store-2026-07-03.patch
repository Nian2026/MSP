+fn source_item_kind(value: &serde_json::Value) -> String {
+    let Some(object) = value.as_object() else {
+        return "unknown".to_string();
+    };
+    object
+        .get("type")
+        .and_then(|kind| kind.as_str())
+        .map(ToOwned::to_owned)
+        .or_else(|| object.keys().find(|key| key.as_str() != "payload").cloned())
+        .unwrap_or_else(|| "unknown".to_string())
+}
+
+fn neutral_event_type(source: &serde_json::Value) -> String {
+    let source_item_kind = source_item_kind(source);
+    let kind = source_item_kind.to_ascii_lowercase();
+    if kind.contains("sessionmeta") || kind.contains("session_meta") {
+        "runtime_context_snapshot".to_string()
+    } else if kind.contains("compacted") {
+        "durable_compaction_checkpoint".to_string()
+    } else if kind.contains("turncontext") || kind.contains("turn_context") {
+        "runtime_context_snapshot".to_string()
+    } else if kind.contains("worldstate") || kind.contains("world_state") {
+        if source_world_state_full(source) == Some(false) {
+            "state_patch".to_string()
+        } else {
+            "state_snapshot".to_string()
+        }
+    } else if kind.contains("responseitem") || kind.contains("response_item") {
+        neutral_response_item_event_type(source)
+    } else if kind.contains("eventmsg") || kind.contains("event_msg") {
+        neutral_event_msg_event_type(source)
+    } else {
+        "status_changed".to_string()
+    }
+}
+
+fn source_payload_type(source: &serde_json::Value) -> String {
+    source
+        .get("payload")
+        .and_then(|payload| payload.get("type"))
+        .and_then(|kind| kind.as_str())
+        .unwrap_or_default()
+        .to_ascii_lowercase()
+}
+
+fn source_world_state_full(source: &serde_json::Value) -> Option<bool> {
+    source
+        .get("payload")
+        .and_then(|payload| payload.get("full"))
+        .and_then(|full| full.as_bool())
+        .or_else(|| source.get("full").and_then(|full| full.as_bool()))
+}
+
+fn neutral_event_msg_event_type(source: &serde_json::Value) -> String {
+    match source_payload_type(source).as_str() {
+        "thread_rolled_back" => "timeline_rollback".to_string(),
+        _ => "status_changed".to_string(),
+    }
+}
+
+fn neutral_response_item_event_type(source: &serde_json::Value) -> String {
+    let payload_type = source_payload_type(source);
+    if payload_type.contains("shell_call") {
+        "command_call".to_string()
+    } else if payload_type.contains("shell_output") {
+        "command_output".to_string()
+    } else if payload_type.ends_with("_output") {
+        "tool_output".to_string()
+    } else if payload_type.contains("function_call")
+        || payload_type.contains("custom_tool_call")
+        || payload_type.contains("web_search_call")
+        || payload_type.contains("image_generation_call")
+    {
+        "tool_call".to_string()
+    } else {
+        "message".to_string()
+    }
+}
