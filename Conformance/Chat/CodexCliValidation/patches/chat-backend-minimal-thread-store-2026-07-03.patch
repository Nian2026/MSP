+fn validation_failpoint(name: &str) {
+    if env::var(VALIDATION_FAILPOINT_ENV).ok().as_deref() == Some(name) {
+        process::abort();
+    }
+}
+
+fn validation_failpoint_if(name: &str, condition: bool) {
+    if condition {
+        validation_failpoint(name);
+    }
+}
+
+fn validation_failpoint_needle_matches<T: Serialize>(value: &T) -> bool {
+    let Some(needle) = env::var(VALIDATION_FAILPOINT_NEEDLE_ENV)
+        .ok()
+        .filter(|needle| !needle.is_empty())
+    else {
+        return true;
+    };
+    serde_json::to_string(value).is_ok_and(|serialized| serialized.contains(&needle))
+}
+
+fn ensure_package_layout(package_path: &Path) -> ThreadStoreResult<()> {
+    fs::create_dir_all(package_path).map_err(io_error)?;
+    fs::create_dir_all(package_path.join("projections")).map_err(io_error)?;
+    fs::create_dir_all(package_path.join("artifacts")).map_err(io_error)?;
+    fs::create_dir_all(package_path.join("blobs")).map_err(io_error)?;
+    fs::create_dir_all(package_path.join("indexes")).map_err(io_error)?;
+    Ok(())
+}
+
+fn reset_canonical_files(package_path: &Path) -> ThreadStoreResult<()> {
+    File::create(package_path.join("timeline.ndjson")).map_err(io_error)?;
+    File::create(package_path.join("journal.ndjson")).map_err(io_error)?;
+    Ok(())
+}
+
+fn append_canonical_items(
+    package_path: &Path,
+    thread_id: ThreadId,
+    items: Vec<RolloutItem>,
+) -> ThreadStoreResult<()> {
+    ensure_package_layout(package_path)?;
+    let mut commit_seq = count_lines(&package_path.join("journal.ndjson"))?;
+    let mut journal = OpenOptions::new()
+        .create(true)
+        .append(true)
+        .open(package_path.join("journal.ndjson"))
+        .map_err(io_error)?;
+    let mut timeline = OpenOptions::new()
+        .create(true)
+        .append(true)
+        .open(package_path.join("timeline.ndjson"))
+        .map_err(io_error)?;
+    for item in items {
+        commit_seq += 1;
+        let now = Utc::now();
+        let source = serde_json::to_value(&item).map_err(json_error)?;
+        let source_item_kind = source_item_kind(&source);
+        let entry = JournalEntry {
+            entry_type: "source_transport".to_string(),
+            created_at: now,
+            commit_seq,
+            thread_id,
+            source_transport: SourceTransportEnvelope {
+                schema: "msp.chat.source_transport.v1".to_string(),
+                payload: source.clone(),
+            },
+            item: item.clone(),
+        };
+        serde_json::to_writer(&mut journal, &entry).map_err(json_error)?;
+        writeln!(journal).map_err(io_error)?;
+        journal.sync_data().map_err(io_error)?;
+
+        let event = TimelineEvent {
+            id: format!("event-{commit_seq:020}"),
+            event_type: neutral_event_type(&source),
+            seq: commit_seq,
+            commit_seq,
+            created_at: now,
+            durability: "durable_replay".to_string(),
+            thread_id,
+            source_transport_ref: format!("journal:{commit_seq}"),
+            source_item_kind,
+            payload: source,
+        };
+        serde_json::to_writer(&mut timeline, &event).map_err(json_error)?;
+        writeln!(timeline).map_err(io_error)?;
+        timeline.sync_data().map_err(io_error)?;
+    }
+    Ok(())
+}
+
+fn rebuild_projections(package_path: &Path) -> ThreadStoreResult<()> {
+    let events = read_timeline_events(package_path)?;
+    write_projection(
+        package_path,
+        "chat-read.ndjson",
+        "chat-read.machine",
+        &events,
+    )?;
+    write_projection(
+        package_path,
+        "model-context.ndjson",
+        "model-context",
+        &events,
+    )?;
+    write_projection(package_path, "audit.ndjson", "audit", &events)?;
+    Ok(())
+}
+
+fn write_projection(
+    package_path: &Path,
+    filename: &str,
+    projection_kind: &str,
+    events: &[TimelineEvent],
+) -> ThreadStoreResult<()> {
+    let path = package_path.join("projections").join(filename);
+    let mut file = File::create(path).map_err(io_error)?;
+    let source_event_ids: Vec<_> = events.iter().map(|event| event.id.clone()).collect();
+    let source_fingerprint = format!(
+        "timeline:{}:{}:{}",
+        events.len(),
+        events.first().map(|event| event.id.as_str()).unwrap_or(""),
+        events.last().map(|event| event.id.as_str()).unwrap_or("")
+    );
+    let header = json!({
+        "record_type": "projection_metadata",
+        "projection_kind": projection_kind,
+        "projection_format": "ndjson",
+        "source_event_range": {
+            "from_seq": events.first().map(|event| event.seq),
+            "to_seq": events.last().map(|event| event.seq)
+        },
+        "source_event_ids": source_event_ids,
+        "source_fingerprint": source_fingerprint,
+        "generator": "codex-chat-backend-validation",
+        "generated_at": Utc::now(),
+        "lossy": false,
+        "redacted": false,
+        "truncated": false
+    });
+    serde_json::to_writer(&mut file, &header).map_err(json_error)?;
+    writeln!(file).map_err(io_error)?;
+    for event in events {
+        let projection_event = json!({
+            "record_type": "projection_event",
+            "projection_kind": projection_kind,
+            "source_event_id": event.id,
+            "source_seq": event.seq,
+            "event": event
+        });
+        serde_json::to_writer(&mut file, &projection_event).map_err(json_error)?;
+        writeln!(file).map_err(io_error)?;
+    }
+    file.sync_data().map_err(io_error)?;
+    Ok(())
+}
+
+fn write_thread_index(package_path: &Path, thread: &StoredThread) -> ThreadStoreResult<()> {
+    let path = package_path.join("indexes").join("thread-metadata.json");
+    if let Some(parent) = path.parent() {
+        fs::create_dir_all(parent).map_err(io_error)?;
+    }
+    write_json_pretty_atomic(&path, thread)
+}
+
+fn write_manifest(package_path: &Path, manifest: &ChatManifest) -> ThreadStoreResult<()> {
+    ensure_package_layout(package_path)?;
+    write_json_pretty_atomic(&package_path.join("manifest.json"), manifest)
+}
+
+fn write_json_pretty_atomic<T: Serialize>(path: &Path, value: &T) -> ThreadStoreResult<()> {
+    let file_name = path
+        .file_name()
+        .and_then(|name| name.to_str())
+        .unwrap_or("data.json");
+    let nonce = Utc::now().timestamp_nanos_opt().unwrap_or_default();
+    let temp_path = path.with_file_name(format!(".{file_name}.{nonce}.tmp"));
+
+    let mut file = File::create(&temp_path).map_err(io_error)?;
+    if let Err(error) = serde_json::to_writer_pretty(&mut file, value) {
+        let _ = fs::remove_file(&temp_path);
+        return Err(json_error(error));
+    }
+    if let Err(error) = writeln!(file) {
+        let _ = fs::remove_file(&temp_path);
+        return Err(io_error(error));
+    }
+    if let Err(error) = file.sync_data() {
+        let _ = fs::remove_file(&temp_path);
+        return Err(io_error(error));
+    }
+    if let Err(error) = fs::rename(&temp_path, path) {
+        let _ = fs::remove_file(&temp_path);
+        return Err(io_error(error));
+    }
+    if let Some(parent) = path.parent()
+        && let Ok(directory) = File::open(parent)
+    {
+        let _ = directory.sync_data();
+    }
+    Ok(())
+}
+
+fn read_manifest(package_path: &Path) -> ThreadStoreResult<ChatManifest> {
+    let file = File::open(package_path.join("manifest.json")).map_err(|err| match err.kind() {
+        std::io::ErrorKind::NotFound => ThreadStoreError::ThreadNotFound {
+            thread_id: thread_id_from_package_path(package_path),
+        },
+        _ => io_error(err),
+    })?;
+    serde_json::from_reader(file).map_err(json_error)
+}
+
+fn materialize_cold_package(plain_path: PathBuf, cold_path: PathBuf) -> ThreadStoreResult<PathBuf> {
+    if plain_path.exists() {
+        return Ok(plain_path);
+    }
+    if cold_path.exists() {
+        fs::rename(&cold_path, &plain_path).map_err(io_error)?;
+        return Ok(plain_path);
+    }
+    Err(ThreadStoreError::ThreadNotFound {
+        thread_id: thread_id_from_package_path(&plain_path),
+    })
+}
+
+fn is_cold_package_path(package_path: &Path) -> bool {
+    package_path
+        .file_name()
+        .and_then(|name| name.to_str())
+        .is_some_and(|name| name.ends_with(".chat.cold"))
+}
+
+fn cold_to_plain_package_path(package_path: &Path) -> PathBuf {
+    let Some(name) = package_path.file_name().and_then(|name| name.to_str()) else {
+        return package_path.to_path_buf();
+    };
+    let Some(thread_id) = name.strip_suffix(".chat.cold") else {
+        return package_path.to_path_buf();
+    };
+    package_path.with_file_name(format!("{thread_id}.chat"))
+}
+
+fn plain_to_cold_package_path(package_path: &Path) -> PathBuf {
+    let Some(name) = package_path.file_name().and_then(|name| name.to_str()) else {
+        return package_path.to_path_buf();
+    };
+    package_path.with_file_name(format!("{name}.cold"))
+}
