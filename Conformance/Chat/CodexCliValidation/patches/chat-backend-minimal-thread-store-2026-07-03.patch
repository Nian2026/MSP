+        local_agent_graph_store_from_state_db(state_db.as_ref()),
+        TEST_INSTALLATION_ID.to_string(),
+        /*attestation_provider*/ None,
+        /*external_time_provider*/ None,
+    );
+
+    let source = manager
+        .start_thread(config.clone())
+        .await
+        .expect("start chat-backed thread");
+    source
+        .thread
+        .shutdown_and_wait()
+        .await
+        .expect("shutdown source thread");
+    let _ = manager.remove_thread(&source.thread_id).await;
+
+    let package_path = temp_dir
+        .path()
+        .join("chat-threads")
+        .join(format!("{}.chat", source.thread_id));
+    assert!(package_path.join("manifest.json").is_file());
+
+    let resumed = manager
+        .resume_thread_from_rollout(
+            config,
+            package_path.clone(),
+            auth_manager,
+            /*parent_trace*/ None,
+            /*supports_openai_form_elicitation*/ false,
+        )
+        .await
+        .expect("resume from chat package path");
+
+    assert_eq!(
+        resumed.session_configured.rollout_path.as_deref(),
+        Some(package_path.as_path())
+    );
+    assert_eq!(
+        resumed.thread.rollout_path().as_deref(),
+        Some(package_path.as_path())
+    );
