+#[derive(Clone, Debug)]
+struct ChatCursor {
+    timestamp: DateTime<Utc>,
+    thread_id: Option<ThreadId>,
+}
+
+fn parse_chat_cursor(token: &str) -> Option<ChatCursor> {
+    let (timestamp, thread_id) = match token.rsplit_once('|') {
+        Some((timestamp, thread_id)) => (timestamp, Some(ThreadId::from_string(thread_id).ok()?)),
+        None => (token, None),
+    };
+    let timestamp = DateTime::parse_from_rfc3339(timestamp)
+        .ok()?
+        .with_timezone(&Utc);
+    Some(ChatCursor {
+        timestamp,
+        thread_id,
+    })
+}
+
+fn thread_sort_timestamp(thread: &StoredThread, sort_key: ThreadSortKey) -> DateTime<Utc> {
+    match sort_key {
+        ThreadSortKey::CreatedAt => thread.created_at,
+        ThreadSortKey::UpdatedAt => thread.updated_at,
+        ThreadSortKey::RecencyAt => thread.recency_at,
+    }
+}
+
+fn cursor_start_index(
+    items: &[StoredThread],
+    cursor: Option<&str>,
+    sort_key: ThreadSortKey,
+    sort_direction: crate::SortDirection,
+) -> usize {
+    let Some(cursor) = cursor else {
+        return 0;
+    };
+    if let Ok(offset) = cursor.parse::<usize>() {
+        return offset.min(items.len());
+    }
+    let Some(cursor) = parse_chat_cursor(cursor) else {
+        return 0;
+    };
+    if let Some(thread_id) = cursor.thread_id
+        && let Some(index) = items
+            .iter()
+            .position(|thread| thread.thread_id == thread_id)
+    {
+        return (index + 1).min(items.len());
+    }
+    items
+        .iter()
+        .position(|thread| {
+            let ordering = thread_sort_timestamp(thread, sort_key)
+                .cmp(&cursor.timestamp)
+                .then_with(|| {
+                    if let Some(thread_id) = cursor.thread_id {
+                        thread.thread_id.to_string().cmp(&thread_id.to_string())
+                    } else {
+                        Ordering::Equal
+                    }
+                });
+            let ordering = match sort_direction {
+                crate::SortDirection::Asc => ordering,
+                crate::SortDirection::Desc => reverse_ordering(ordering),
+            };
+            ordering == Ordering::Greater
+        })
+        .unwrap_or(items.len())
+}
+
+fn thread_cursor(
+    thread: &StoredThread,
+    sort_key: ThreadSortKey,
+    include_thread_id_tiebreaker: bool,
+) -> String {
+    let timestamp = match sort_key {
+        ThreadSortKey::CreatedAt => {
+            thread_sort_timestamp(thread, sort_key).to_rfc3339_opts(SecondsFormat::Secs, true)
+        }
+        ThreadSortKey::UpdatedAt | ThreadSortKey::RecencyAt => {
+            thread_sort_timestamp(thread, sort_key).to_rfc3339_opts(SecondsFormat::AutoSi, true)
+        }
+    };
+    if include_thread_id_tiebreaker || matches!(sort_key, ThreadSortKey::RecencyAt) {
+        format!("{timestamp}|{}", thread.thread_id)
+    } else {
+        timestamp
+    }
+}
+
+fn paginate_threads(
+    items: Vec<StoredThread>,
+    page_size: usize,
+    cursor: Option<String>,
+    sort_key: ThreadSortKey,
+    sort_direction: crate::SortDirection,
+    include_thread_id_tiebreaker: bool,
+) -> ThreadStoreResult<ThreadPage> {
+    let start = cursor_start_index(&items, cursor.as_deref(), sort_key, sort_direction);
+    let page_size = page_size.max(1);
+    let end = (start + page_size).min(items.len());
+    let next_cursor = (end < items.len())
+        .then(|| thread_cursor(&items[end - 1], sort_key, include_thread_id_tiebreaker));
+    Ok(ThreadPage {
+        items: items[start.min(items.len())..end].to_vec(),
+        next_cursor,
+    })
+}
+
+fn paginate_search_results(
+    items: Vec<StoredThreadSearchResult>,
+    page_size: usize,
+    cursor: Option<String>,
+    sort_key: ThreadSortKey,
+    sort_direction: crate::SortDirection,
+) -> ThreadStoreResult<ThreadSearchPage> {
+    let thread_items = items
+        .iter()
+        .map(|result| result.thread.clone())
+        .collect::<Vec<_>>();
+    let start = cursor_start_index(&thread_items, cursor.as_deref(), sort_key, sort_direction);
+    let page_size = page_size.max(1);
+    let end = (start + page_size).min(items.len());
+    let next_cursor =
+        (end < items.len()).then(|| thread_cursor(&items[end - 1].thread, sort_key, false));
+    Ok(ThreadSearchPage {
+        items: items[start.min(items.len())..end].to_vec(),
+        next_cursor,
+    })
+}
