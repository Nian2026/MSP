+            .is_some_and(|name| name.to_lowercase().contains(&needle))
+        || thread
+            .first_user_message
+            .as_ref()
+            .is_some_and(|message| message.to_lowercase().contains(&needle))
+}
+
+fn apply_relation_filter(
+    items: &mut Vec<StoredThread>,
+    relation_universe: &[(ThreadId, Option<ThreadId>)],
+    relation_filter: Option<ThreadRelationFilter>,
+) {
+    match relation_filter {
+        Some(ThreadRelationFilter::DirectChildrenOf(parent_thread_id)) => {
+            items.retain(|thread| thread.parent_thread_id == Some(parent_thread_id));
+        }
+        Some(ThreadRelationFilter::DescendantsOf(ancestor_thread_id)) => {
+            let mut subtree = HashSet::from([ancestor_thread_id]);
+            loop {
+                let mut discovered = false;
+                for (thread_id, parent_thread_id) in relation_universe {
+                    if parent_thread_id
+                        .is_some_and(|parent_thread_id| subtree.contains(&parent_thread_id))
+                    {
+                        discovered |= subtree.insert(*thread_id);
+                    }
+                }
+                if !discovered {
+                    break;
+                }
+            }
+            items.retain(|thread| {
+                thread.thread_id != ancestor_thread_id && subtree.contains(&thread.thread_id)
+            });
+        }
+        None => {}
+    }
+}
+
+fn sort_threads(
+    items: &mut [StoredThread],
+    sort_key: ThreadSortKey,
+    sort_direction: crate::SortDirection,
+) {
+    items.sort_by(|left, right| {
+        let ordering = match sort_key {
+            ThreadSortKey::CreatedAt => left.created_at.cmp(&right.created_at),
+            ThreadSortKey::UpdatedAt => left.updated_at.cmp(&right.updated_at),
+            ThreadSortKey::RecencyAt => left.recency_at.cmp(&right.recency_at),
+        }
+        .then_with(|| left.thread_id.to_string().cmp(&right.thread_id.to_string()));
+        match sort_direction {
+            crate::SortDirection::Asc => ordering,
+            crate::SortDirection::Desc => reverse_ordering(ordering),
+        }
+    });
+}
+
+fn sort_search_results(
+    items: &mut [StoredThreadSearchResult],
+    sort_key: ThreadSortKey,
+    sort_direction: crate::SortDirection,
+) {
+    items.sort_by(|left, right| {
+        let ordering = match sort_key {
+            ThreadSortKey::CreatedAt => left.thread.created_at.cmp(&right.thread.created_at),
+            ThreadSortKey::UpdatedAt => left.thread.updated_at.cmp(&right.thread.updated_at),
+            ThreadSortKey::RecencyAt => left.thread.recency_at.cmp(&right.thread.recency_at),
+        }
+        .then_with(|| {
+            left.thread
+                .thread_id
+                .to_string()
+                .cmp(&right.thread.thread_id.to_string())
+        });
+        match sort_direction {
+            crate::SortDirection::Asc => ordering,
+            crate::SortDirection::Desc => reverse_ordering(ordering),
+        }
+    });
+}
+
+fn reverse_ordering(ordering: Ordering) -> Ordering {
+    match ordering {
+        Ordering::Less => Ordering::Greater,
+        Ordering::Equal => Ordering::Equal,
+        Ordering::Greater => Ordering::Less,
+    }
+}
