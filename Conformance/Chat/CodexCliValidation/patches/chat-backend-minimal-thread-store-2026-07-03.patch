+    #[test]
+    fn source_item_kind_reads_flattened_rollout_type() {
+        assert_eq!(
+            source_item_kind(&json!({"type": "session_meta", "payload": {}})),
+            "session_meta"
+        );
+        assert_eq!(
+            neutral_event_type(&json!({"type": "session_meta", "payload": {}})),
+            "runtime_context_snapshot"
+        );
+        assert_eq!(
+            neutral_event_type(&json!({"type": "response_item", "payload": {"type": "message"}})),
+            "message"
+        );
+        assert_eq!(
+            neutral_event_type(
+                &json!({"type": "response_item", "payload": {"type": "image_generation_call"}})
+            ),
+            "tool_call"
+        );
+        assert_eq!(
+            neutral_event_type(
+                &json!({"type": "event_msg", "payload": {"type": "thread_rolled_back", "num_turns": 1}})
+            ),
+            "timeline_rollback"
+        );
+        assert_eq!(
+            neutral_event_type(&json!({"type": "world_state", "payload": {"full": true}})),
+            "state_snapshot"
+        );
+        assert_eq!(
+            neutral_event_type(&json!({"type": "world_state", "payload": {"full": false}})),
+            "state_patch"
+        );
+    }
