+fn package_paths(root: &Path) -> ThreadStoreResult<Vec<PathBuf>> {
+    if !root.exists() {
+        return Ok(Vec::new());
+    }
+    let mut paths = Vec::new();
+    for entry in fs::read_dir(root).map_err(io_error)? {
+        let entry = entry.map_err(io_error)?;
+        let path = entry.path();
+        if !path.is_dir() {
+            continue;
+        }
+        if path.extension().is_some_and(|ext| ext == "chat") {
+            paths.push(path);
+        } else if is_cold_package_path(&path) {
+            let plain_path = cold_to_plain_package_path(&path);
+            if !plain_path.exists() {
+                paths.push(path);
+            }
+        }
+    }
+    Ok(paths)
+}
