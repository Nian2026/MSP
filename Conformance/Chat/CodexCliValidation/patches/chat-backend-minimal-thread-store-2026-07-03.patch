+    #[tokio::test]
+    async fn reads_cold_package_and_materializes_for_writes() {
+        let temp = TempDir::new().expect("temp dir");
+        let root = temp.path().join("threads");
+        let store = ChatThreadStore::new(ChatThreadStoreConfig { root: root.clone() });
+        let thread_id =
+            ThreadId::from_string(&uuid::Uuid::now_v7().to_string()).expect("thread id");
+
+        store
+            .create_thread(create_params(thread_id))
+            .await
+            .expect("create");
+        store
+            .append_items(AppendThreadItemsParams {
+                thread_id,
+                items: vec![RolloutItem::EventMsg(EventMsg::UserMessage(
+                    UserMessageEvent {
+                        client_id: None,
+                        message: "first cold package message".to_string(),
+                        images: None,
+                        ..Default::default()
+                    },
+                ))],
+            })
+            .await
+            .expect("append first");
+
+        let plain = root.join(format!("{thread_id}.chat"));
+        let cold = root.join(format!("{thread_id}.chat.cold"));
+        std::fs::rename(&plain, &cold).expect("move to cold");
+        assert!(!plain.exists());
+        assert!(cold.exists());
+
+        let cold_thread = store
+            .read_thread(ReadThreadParams {
+                thread_id,
+                include_archived: false,
+                include_history: true,
+            })
+            .await
+            .expect("read cold");
+        assert_eq!(cold_thread.thread_id, thread_id);
+        assert_eq!(cold_thread.history.expect("history").items.len(), 2);
+        assert!(!plain.exists());
+        assert!(cold.exists());
+
+        let cold_list = store
+            .list_threads(ListThreadsParams {
+                page_size: 10,
+                cursor: None,
+                sort_key: ThreadSortKey::CreatedAt,
+                sort_direction: crate::SortDirection::Desc,
+                allowed_sources: Vec::new(),
+                model_providers: None,
+                cwd_filters: None,
+                archived: false,
+                search_term: None,
+                relation_filter: None,
+                use_state_db_only: false,
+            })
+            .await
+            .expect("list cold");
+        assert_eq!(cold_list.items.len(), 1);
+
+        store
+            .append_items(AppendThreadItemsParams {
+                thread_id,
+                items: vec![RolloutItem::EventMsg(EventMsg::UserMessage(
+                    UserMessageEvent {
+                        client_id: None,
+                        message: "second materialized package message".to_string(),
+                        images: None,
+                        ..Default::default()
+                    },
+                ))],
+            })
+            .await
+            .expect("append materializes");
+        assert!(plain.exists());
+        assert!(!cold.exists());
+
+        let history = store
+            .load_history(LoadThreadHistoryParams {
+                thread_id,
+                include_archived: false,
+            })
+            .await
+            .expect("history after materialize");
+        assert_eq!(history.items.len(), 3);
+
+        std::fs::create_dir_all(&cold).expect("create cold sibling");
+        store
+            .delete_thread(DeleteThreadParams { thread_id })
+            .await
+            .expect("delete siblings");
+        assert!(!plain.exists());
+        assert!(!cold.exists());
+    }
