{
  "profile": "msp-v1-linux-command-layer",
  "case_type": "linux-compatible-observable-behavior",
  "cases": [
    {
      "id": "shell-builtins-and-state",
      "covered_commands": [
        ":",
        "[",
        "[[",
        "builtin",
        "cd",
        "command",
        "echo",
        "env",
        "false",
        "printf",
        "printenv",
        "pwd",
        "test",
        "true",
        "type",
        "which"
      ],
      "script": [
        ":",
        "true",
        "false || true",
        "test -n value",
        "[ 3 -gt 2 ]",
        "[[ value = value ]]",
        "pwd | grep -q '^/$'",
        "mkdir -p dir",
        "cd dir",
        "pwd | grep -q '^/dir$'",
        "command -v printf | grep -q '^printf$'",
        "builtin printf 'builtin\\n' | grep -q '^builtin$'",
        "type -t cd | grep -q '^builtin$'",
        "which awk | grep -q '^/usr/bin/awk$'",
        "env FOO=bar env | grep -q '^FOO=bar$'",
        "FOO=bar printenv FOO | grep -q '^bar$'",
        "echo echo-ok | grep -q '^echo-ok$'",
        "printf 'shell-ok\\n'"
      ],
      "stdout": "shell-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "filesystem-and-path-utilities",
      "covered_commands": [
        "basename",
        "cat",
        "chmod",
        "cp",
        "cut",
        "dirname",
        "du",
        "find",
        "link",
        "ln",
        "ls",
        "mkdir",
        "mktemp",
        "mv",
        "pathchk",
        "readlink",
        "realpath",
        "rm",
        "sort",
        "stat",
        "touch"
      ],
      "script": [
        "mkdir -p a/sub",
        "printf 'alpha\\n' > a/file.txt",
        "cp a/file.txt a/copy.txt",
        "mv a/copy.txt a/moved.txt",
        "ln a/file.txt a/hard.txt",
        "printf 'hard!\\n' > a/hard.txt",
        "link a/file.txt a/link-hard.txt",
        "cat a/link-hard.txt | grep -q '^hard!$'",
        "ln -s moved.txt a/link.txt",
        "chmod 600 a/moved.txt",
        "touch a/empty.txt",
        "cat a/file.txt | grep -q '^hard!$'",
        "cat a/link.txt | grep -q '^alpha$'",
        "stat -c '%s' a/moved.txt | grep -q '^6$'",
        "stat -c '%a' a/moved.txt | grep -q '^600$'",
        "du -b a/moved.txt | cut -f1 | grep -q '^6$'",
        "readlink a/link.txt | grep -q '^moved.txt$'",
        "realpath a/moved.txt | grep -q '^/a/moved.txt$'",
        "basename /a/moved.txt .txt | grep -q '^moved$'",
        "dirname /a/moved.txt | grep -q '^/a$'",
        "find /a -maxdepth 1 -type f -name '*.txt' -print | sort | grep -q '^/a/file.txt$'",
        "find a -maxdepth 1 -type f -name '*.txt' -print | sort | grep -q '^a/file.txt$'",
        "find a -path 'a/sub/*' -o -type f -empty -print | grep -q '^a/empty.txt$'",
        "find /a -maxdepth 1 -type l -print | grep -q '^/a/link.txt$'",
        "find /a -maxdepth 1 -type f -name '*.txt' -exec printf '<%s>\\n' {} \\; | grep -q '^</a/file.txt>$'",
        "find /a -maxdepth 1 -type f -name '*.txt' -exec printf '[%s]\\n' {} + | grep -q '^\\[/a/file.txt\\]$'",
        "find /a -maxdepth 1 -type f -name '*.txt' -printf '%10f|%-5.2f|%04s|%%\\n' | grep -q '^  file.txt|fi   |0006|%$'",
        "pathchk ok dir/file",
        "mktemp case.XXXXXX | grep -q '^case\\.'",
        "ls a | grep -q '^moved.txt$'",
        "rm a/empty.txt",
        "test ! -e a/empty.txt",
        "printf 'filesystem-ok\\n'"
      ],
      "stdout": "filesystem-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "text-search-and-stream-utilities",
      "covered_commands": [
        "awk",
        "cmp",
        "comm",
        "diff",
        "grep",
        "head",
        "join",
        "nl",
        "paste",
        "rg",
        "sed",
        "tail",
        "tac",
        "tee",
        "tr",
        "uniq",
        "wc",
        "xargs"
      ],
      "setup_files": [
        { "path": "data/letters.txt", "content": "b\nalpha\nbeta\nalpha\n" },
        { "path": "data/nums.txt", "content": "2\n10\n1\n" },
        { "path": "data/repeat.txt", "content": "alpha\nalpha\nbeta\n" },
        { "path": "data/left.txt", "content": "1 apple\n2 banana\n" },
        { "path": "data/left-copy.txt", "content": "1 apple\n2 banana\n" },
        { "path": "data/right.txt", "content": "1 red\n2 yellow\n" },
        { "path": "data/comm-a.txt", "content": "a\nb\n" },
        { "path": "data/comm-b.txt", "content": "b\nc\n" },
        { "path": "data/word.txt", "content": "hello\n" },
        { "path": "data/awk.txt", "content": "a 1\nb 2\n" },
        { "path": "data/xargs.txt", "content": "alpha beta\n" }
      ],
      "script": [
        "grep -q alpha data/letters.txt",
        "rg alpha data/letters.txt | grep -q alpha",
        "head -n 1 data/letters.txt | grep -q '^b$'",
        "tail -n 1 data/letters.txt | grep -q '^alpha$'",
        "wc -l data/letters.txt | grep -q '4'",
        "tac data/nums.txt | head -n 1 | grep -q '^1$'",
        "cut -d ' ' -f2 data/left.txt | head -n 1 | grep -q '^apple$'",
        "nl -ba data/nums.txt | grep -q '1.*2'",
        "sort -n data/nums.txt | head -n 1 | grep -q '^1$'",
        "uniq -c data/repeat.txt | grep -q '2 alpha'",
        "tr 'a-z' 'A-Z' < data/word.txt | grep -q '^HELLO$'",
        "join data/left.txt data/right.txt | grep -q '1 apple red'",
        "comm data/comm-a.txt data/comm-b.txt > comm.out",
        "paste data/left.txt data/right.txt | grep -q apple",
        "tee tee.out < data/word.txt | grep -q hello",
        "diff data/left.txt data/left-copy.txt",
        "cmp data/left.txt data/left-copy.txt",
        "sed 's/alpha/ALPHA/' data/letters.txt | grep -q ALPHA",
        "awk '{sum += $2} END {print sum}' data/awk.txt | grep -q '^3$'",
        "xargs printf '%s\\n' < data/xargs.txt | grep -q beta",
        "printf 'text-ok\\n'"
      ],
      "stdout": "text-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "data-numeric-metadata-and-process-utilities",
      "covered_commands": [
        "base64",
        "bc",
        "cksum",
        "date",
        "factor",
        "file",
        "ldd",
        "md5sum",
        "nproc",
        "numfmt",
        "od",
        "ps",
        "seq",
        "sha1sum",
        "sha256sum",
        "sum",
        "timeout",
        "tty",
        "xxd",
        "yes"
      ],
      "script": [
        "printf abc > bytes.txt",
        "base64 bytes.txt | grep -q '^YWJj$'",
        "printf '/w==' | base64 -d > binary-byte.bin; od -An -tx1 binary-byte.bin | grep -q '^ ff$'",
        "md5sum bytes.txt | grep -q '^900150983cd24fb0d6963f7d28e17f72'",
        "md5sum bytes.txt > bytes.md5",
        "md5sum -c bytes.md5 | grep -q '^bytes.txt: OK$'",
        "sha1sum bytes.txt | grep -q '^a9993e364706816aba3e25717850c26c9cd0d89d'",
        "sha256sum bytes.txt | grep -q '^ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'",
        "cksum bytes.txt | grep -q '^1219131554 3'",
        "sum -s bytes.txt | grep -q '^294 1 bytes.txt$'",
        "od -An -tx1 bytes.txt | tr -d ' \\n' | grep -q '^616263$'",
        "od bytes.txt > od-default.actual; printf '0000000 061141 000143\\n0000003\\n' > od-default.expected; cmp od-default.expected od-default.actual",
        "od -An -tx1c bytes.txt > od-mixed.actual; printf '  61  62  63\\n   a   b   c\\n' > od-mixed.expected; cmp od-mixed.expected od-mixed.actual",
        "printf 'AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA' > repeat.txt; od -An -tx1 repeat.txt > od-repeat.actual; printf ' 41 41 41 41 41 41 41 41 41 41 41 41 41 41 41 41\\n*\\n' > od-repeat.expected; cmp od-repeat.expected od-repeat.actual",
        "xxd -p bytes.txt | grep -q '^616263$'",
        "printf '2+3*4\\n' | bc | grep -q '^14$'",
        "seq -s, 1 3 | grep -q '^1,2,3$'",
        "seq 3 > seq-desc.actual; seq 3 1 >> seq-desc.actual; seq 3 -1 1 >> seq-desc.actual; printf '1\\n2\\n3\\n3\\n2\\n1\\n' > seq-desc.expected; cmp seq-desc.expected seq-desc.actual",
        "seq 0 .1 .3 > seq-decimal.actual; printf '0.0\\n0.1\\n0.2\\n0.3\\n' > seq-decimal.expected; cmp seq-decimal.expected seq-decimal.actual",
        "seq -f 'item:%04.1f' 1 2 > seq-format.actual; printf 'item:01.0\\nitem:02.0\\n' > seq-format.expected; cmp seq-format.expected seq-format.actual",
        "seq -w -2 2 > seq-width.actual; printf -- '-2\\n-1\\n00\\n01\\n02\\n' > seq-width.expected; cmp seq-width.expected seq-width.actual",
        "factor 12 | grep -q '^12: 2 2 3$'",
        "printf '1500\\n' | numfmt --to=si | grep -q '^1.5K$'",
        "yes ok | head -n 2 | uniq | grep -q '^ok$'",
        "timeout 0 printf timeout-ok | grep -q '^timeout-ok$'",
        "tty | grep -q '^not a tty$'",
        "nproc --ignore=9999 | grep -q '^1$'",
        "date -u -d @0 '+%F %T %z %:z %e %D %j %u %w %y' | grep -F -q '1970-01-01 00:00:00 +0000 +00:00  1 01/01/70 001 4 4 70'",
        "date -u -d @0 -Iseconds | grep -F -q '1970-01-01T00:00:00+00:00'",
        "date --utc --date=@0 --iso-8601=ns | grep -F -q '1970-01-01T00:00:00,000000000+00:00'",
        "date -u --date @0 --rfc-3339=seconds | grep -F -q '1970-01-01 00:00:00+00:00'",
        "file -b bytes.txt | grep -q 'ASCII'",
        "ldd --version | grep -q 'GLIBC'",
        "ps -o pid,comm | grep -q 'bash'",
        "printf 'data-numeric-process-ok\\n'"
      ],
      "stdout": "data-numeric-process-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "core100-filesystem-extension-utilities",
      "covered_commands": [
        "install",
        "rmdir",
        "tree",
        "truncate",
        "unlink"
      ],
      "script": [
        "printf abc > src",
        "install src dst",
        "stat -c '%a:%s' dst | grep -q '^755:3$'",
        "truncate -s 5 f.bin",
        "stat -c '%s' f.bin | grep -q '^5$'",
        "mkdir empty-dir",
        "rmdir empty-dir",
        "test ! -e empty-dir",
        ": > victim.txt",
        "unlink victim.txt",
        "test ! -e victim.txt",
        "mkdir -p tree-root/sub",
        ": > tree-root/file",
        "tree --charset ascii tree-root > tree.actual",
        "grep -q 'file' tree.actual",
        "printf 'filesystem-core100-ok\\n'"
      ],
      "stdout": "filesystem-core100-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "core100-byte-stream-and-text-layout-utilities",
      "covered_commands": [
        "dd",
        "expand",
        "expr",
        "fmt",
        "fold",
        "shuf",
        "split",
        "strings",
        "tsort",
        "unexpand"
      ],
      "script": [
        "printf abcdef | dd bs=2 count=2 status=none > dd.actual",
        "printf abcd > dd.expected",
        "cmp dd.expected dd.actual",
        "printf abcdef | split -b 2 - chunk-",
        "find . -maxdepth 1 -name 'chunk-*' -printf '%f:%s\\n' | sort > split.actual",
        "printf 'chunk-aa:2\\nchunk-ab:2\\nchunk-ac:2\\n' > split.expected",
        "cmp split.expected split.actual",
        "printf '0123456789abcdef' > random.bin",
        "printf 'a\\nb\\nc\\n' | shuf --random-source=random.bin > shuf.actual",
        "printf 'a\\nb\\nc\\n' > shuf.expected",
        "cmp shuf.expected shuf.actual",
        "printf 'a b\\nb c\\n' | tsort > tsort.actual",
        "printf 'a\\nb\\nc\\n' > tsort.expected",
        "cmp tsort.expected tsort.actual",
        "expr 2 + 3 | grep -q '^5$'",
        "printf 'abcde\\n' > strings.txt",
        "strings strings.txt | grep -q '^abcde$'",
        "printf abcdef | fold -w 3 > fold.actual",
        "printf 'abc\\ndef' > fold.expected",
        "cmp fold.expected fold.actual",
        "printf 'a\\tb\\n' | expand -t 4 > expand.actual",
        "printf 'a   b\\n' > expand.expected",
        "cmp expand.expected expand.actual",
        "printf '        x\\n' | unexpand > unexpand.actual",
        "printf '\\tx\\n' > unexpand.expected",
        "cmp unexpand.expected unexpand.actual",
        "printf 'alpha beta gamma delta\\n' | fmt -w 12 > fmt.actual",
        "printf 'alpha beta\\ngamma delta\\n' > fmt.expected",
        "cmp fmt.expected fmt.actual",
        "printf 'byte-layout-ok\\n'"
      ],
      "stdout": "byte-layout-ok\n",
      "stderr": "",
      "exit_code": 0
    },
    {
      "id": "core100-identity-encoding-and-time-utilities",
      "covered_commands": [
        "b2sum",
        "base32",
        "basenc",
        "hostname",
        "groups",
        "id",
        "sha512sum",
        "sleep",
        "uname",
        "whoami"
      ],
      "script": [
        "uname | grep -q '^Linux$'",
        "hostname | grep -q '^happy-swan-1.localdomain$'",
        "whoami | grep -q '^nobody$'",
        "groups nobody | grep -q '^nobody : nogroup$'",
        "id -u | grep -q '^65534$'",
        "sleep 0",
        "printf hello | base32 | grep -q '^NBSWY3DP$'",
        "printf hello | basenc --base64 | grep -q '^aGVsbG8=$'",
        "printf hello > bytes.txt",
        "sha512sum bytes.txt | wc -c | grep -q '^140$'",
        "b2sum bytes.txt | wc -c | grep -q '^140$'",
        "printf 'identity-encoding-ok\\n'"
      ],
      "stdout": "identity-encoding-ok\n",
      "stderr": "",
      "exit_code": 0
    }
  ]
}
